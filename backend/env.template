# Copy this file to `.env` and fill in the values you use locally.
# Never commit your real secrets.

# Set one (or both) providers
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
JUDGE_MODEL=gpt-4o-mini

# Choose which provider to use: openai, gemini, or auto (prefer openai then gemini)
LLM_PROVIDER=auto

# SerpAPI key for Google Scholar scraping (get one at serpapi.com)
SERPAPI_API_KEY=your-serpapi-key

# Frontend origins that can call this API
CORS_ALLOW_ORIGINS=http://localhost:5173

# Optional: absolute path to scraper snapshots (*_raw.json). Default: <backend>/data/raw_authors
# RESEARCH_RAW_AUTHORS_DIR=/app/backend/data/raw_authors

